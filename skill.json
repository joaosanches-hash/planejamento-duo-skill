{
  "name": "planejamento",
  "displayName": "Planejamento Estratégico — Duo Digital Growth",
  "description": "Gera o planejamento estratégico inicial de um novo cliente em HTML, seguindo a estrutura do método de onboarding da Duo Digital Growth (14 seções: Missão BASE, Market Sizing, Jobs to Be Done, Benchmarking, SWOT, Personas, Processo Decisório, OKRs, Canais, RACI, Investimento, Funil, Cronograma D0–D15). Transforma transcripts de reunião, handoff e dados do cliente em documento HTML profissional para apresentação.",
  "version": "1.1.0",
  "author": "Duo Digital Growth",
  "license": "private",
  "keywords": [
    "planejamento",
    "marketing-digital",
    "trafego-pago",
    "meta-ads",
    "google-ads",
    "metodo-base",
    "onboarding"
  ],
  "platforms": ["claude"],
  "command": "/planejamento",
  "commandFile": ".claude/skills/planejamento/SKILL.md",
  "inputs": [
    "transcript da reunião de vendas (.txt)",
    "transcript da reunião de boas-vindas (.txt)",
    "formulário handoff preenchido",
    "instagram do cliente",
    "site do cliente (quando disponível)"
  ],
  "output": "saidas/planejamentos/planejamento_[nome-do-cliente].html",
  "sections": [
    "Missão / Método BASE",
    "Entregáveis BASE (B/A/S/E)",
    "Market Sizing (TAM > SAM > SOM)",
    "Jobs to Be Done",
    "Benchmarking de Mídia",
    "Análise SWOT",
    "Definição de Audiência / Personas ICP",
    "Processo Decisório",
    "Objetivo SMART / OKRs",
    "Canais Prioritários",
    "Plano de Execução / Matriz RACI",
    "Investimento Orçamentário / Plano de Mídia",
    "Definição do Funil",
    "Cronograma e Próximos Passos (D0–D15)"
  ]
}
